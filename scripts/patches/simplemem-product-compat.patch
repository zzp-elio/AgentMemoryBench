diff --git a/simplemem/core/database/vector_store.py b/simplemem/core/database/vector_store.py
index f287031..a9c20b0 100644
--- a/simplemem/core/database/vector_store.py
+++ b/simplemem/core/database/vector_store.py
@@ -6 +6 @@ Implements three-layer indexing I(m_k):
-- Lexical Layer: l_k = E_sparse(m_k) - BM25 keyword matching (Tantivy FTS)
+- Lexical Layer: l_k = E_sparse(m_k) - BM25 keyword matching (Lance native FTS)
@@ -24 +24 @@ class VectorStore:
-    2. Lexical Layer: Tantivy FTS for exact keyword matching
+    2. Lexical Layer: Lance native FTS for exact keyword matching
@@ -80,17 +80,10 @@ class VectorStore:
-            if self._is_cloud_storage:
-                # Use native FTS for cloud storage (Tantivy only works with local filesystem)
-                self.table.create_fts_index(
-                    "lossless_restatement",
-                    use_tantivy=False,
-                    replace=True
-                )
-                print("FTS index created (native mode for cloud storage)")
-            else:
-                # Use Tantivy FTS for local storage (better performance)
-                self.table.create_fts_index(
-                    "lossless_restatement",
-                    use_tantivy=True,
-                    tokenizer_name="en_stem",
-                    replace=True
-                )
-                print("FTS index created (Tantivy mode)")
+            # LanceDB >=0.34 removed the legacy Python-Tantivy backend and
+            # raises whenever use_tantivy=True. Native FTS is now the common
+            # local/cloud implementation; en_stem remains a supported
+            # compatibility alias for the same English stemming policy.
+            self.table.create_fts_index(
+                "lossless_restatement",
+                tokenizer_name="en_stem",
+                replace=True
+            )
+            print("FTS index created (Lance native mode)")
