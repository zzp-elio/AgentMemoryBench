{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^compact$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/project_guard.py\"",
            "timeout": 5,
            "statusMessage": "Injecting compact recovery gate"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/project_guard.py\"",
            "timeout": 5,
            "statusMessage": "Checking project Git discipline"
          }
        ]
      }
    ]
  }
}
